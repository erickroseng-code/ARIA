# ARIA Production Environment Variables
# Copy this file to .env.production and fill in all values.
# NEVER commit .env.production to source control.

# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# ─── AI Provider ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk_or_v1_xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_DEFAULT=anthropic/claude-3-5-sonnet

# ─── Web Authentication ────────────────────────────────────────────────────────
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=change_me_long_random_secret_128_chars
JWT_SECRET=change_me_another_long_random_secret

# ─── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_ALLOWED_USER_ID=your_telegram_numeric_id

# ─── Notion ────────────────────────────────────────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CLIENTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── ClickUp ───────────────────────────────────────────────────────────────────
CLICKUP_API_KEY=pk_164632817_xxxxxxxxxxxxxxxxxxxxxxxxxx
CLICKUP_TEAM_ID=xxxxxxxxxx
CLICKUP_LIST_ID=xxxxxxxxxxxxxxxxxx
CLICKUP_USER_ID=164632817

# ─── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://your-api.railway.app/api/calendar/oauth/callback

# ─── Monitoring (optional but recommended) ─────────────────────────────────────
SENTRY_DSN=https://xxxxxxxxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxxx

# ─── Production URLs ───────────────────────────────────────────────────────────
PRODUCTION_URL=https://your-api.railway.app
WEB_URL=https://your-app.vercel.app
