// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Integration {
  id           String   @id @default(uuid())
  provider     String   @unique // e.g. "google"
  refreshToken String?  // Optional since access could just use short-lived tokens, but we use refresh
  accessToken  String?
  expiresAt    DateTime?
  isValid      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MaverickAnalysis {
  id              String   @id @default(uuid())
  username        String   // Instagram username analyzed
  profile         Json     // ProfileAnalysis data
  analysis        Json     // Analysis section
  strategy        Json     // Strategy section
  fullReport      Json     // Complete MaverickReport
  status          String   @default("completed") // completed, failed, pending
  error           String?  // Error message if failed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([username])
  @@index([createdAt])
}
