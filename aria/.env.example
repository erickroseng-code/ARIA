# === AI / LLM ===
OPENROUTER_API_KEY=sk-or-v1-...    # OpenRouter API key (obrigatório)
GROQ_API_KEY=gsk_...               # Groq API key para o chat da API
ANTHROPIC_API_KEY=sk-ant-...       # Anthropic direto (opcional)
OPENAI_API_KEY=sk-...              # Whisper API para transcrição de áudio

# === Telegram ===
TELEGRAM_BOT_TOKEN=...
ALLOWED_TELEGRAM_IDS=123456789,987654321

# === Auth (Web) ===
NEXTAUTH_SECRET=...                # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=...                     # openssl rand -base64 32

# === CORS ===
# Lista de origens permitidas separadas por vírgula
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# === Google Workspace ===
GOOGLE_CLIENT_ID=...               # Google Cloud Console → OAuth 2.0 Client ID
GOOGLE_CLIENT_SECRET=...           # Google Cloud Console → OAuth 2.0 Client Secret
GOOGLE_REFRESH_TOKEN=...           # Obtido após autorização OAuth
# Redirect URI (deve coincidir exatamente com o configurado no Google Cloud Console)
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# === Notion ===
NOTION_API_KEY=secret_...          # Integration token from notion.so/my-integrations
NOTION_DATABASE_ID=...             # Clients database ID
NOTION_TASKS_DATABASE_ID=...       # Tasks database ID (opcional)

# === ClickUp ===
CLICKUP_API_TOKEN=pk_...           # Personal API token from ClickUp Settings
CLICKUP_TEAM_ID=...                # Workspace ID from ClickUp URL
CLICKUP_DEFAULT_LIST_ID=...        # Default list ID for task creation
CLICKUP_USER_ID=...                # Your ClickUp user ID (Settings → Profile)

# === App ===
API_URL=http://localhost:3001
NODE_ENV=development
LOG_LEVEL=debug
