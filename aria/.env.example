# === AI ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...           # Whisper API

# === Telegram ===
TELEGRAM_BOT_TOKEN=...
ALLOWED_TELEGRAM_IDS=123456789,987654321

# === Auth (Web) ===
NEXTAUTH_SECRET=...             # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=...

# === Integrations ===
# Notion
NOTION_API_KEY=secret_...           # Integration token from notion.so/my-integrations
NOTION_DATABASE_ID=...              # Clients database ID
NOTION_TASKS_DATABASE_ID=...        # Tasks database ID (optional, uses fallback if empty)

# ClickUp
CLICKUP_API_KEY=pk_...              # Personal API token from ClickUp Settings
CLICKUP_TEAM_ID=...                 # Workspace ID from ClickUp URL
CLICKUP_LIST_ID=...                 # Default list ID for task creation
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...

# === App ===
API_URL=http://localhost:3001
NODE_ENV=development
LOG_LEVEL=debug
