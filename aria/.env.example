# ═══════════════════════════════════════════════════════════════════════════
# Aria — Environment Variables
# Copy this file to .env and fill in your values.
# OBRIGATÓRIO = required for the API to start
# OPCIONAL    = feature-specific, API starts without it
# ═══════════════════════════════════════════════════════════════════════════

# === App ===
PORT=3001                          # OPCIONAL — porta da API (default: 3001)
NODE_ENV=development               # OPCIONAL — development | production | test
LOG_LEVEL=debug                    # OPCIONAL — debug | info | warn | error

# === Database ===
# SQLite local (default):
DATABASE_URL=file:./prisma/dev.db  # OPCIONAL — Turso/libsql em produção: libsql://...
# Turso (produção no Render):
# DATABASE_URL=libsql://aria-db-usuario.turso.io
# TURSO_AUTH_TOKEN=eyJ...         # OPCIONAL — token Turso (se usar libsql cloud)

# === AI / LLM ===
OPENROUTER_API_KEY=sk-or-v1-...   # OBRIGATÓRIO — openrouter.ai/keys
GROQ_API_KEY=gsk_...              # OPCIONAL — groq.com/keys (fallback para chat)
OPENAI_API_KEY=sk-...             # OPCIONAL — Whisper API para transcrição de áudio
ANTHROPIC_API_KEY=sk-ant-...      # OPCIONAL — Anthropic direto (fallback)

# === Auth ===
JWT_SECRET=change-me-in-production  # OBRIGATÓRIO — openssl rand -base64 32
NEXTAUTH_SECRET=change-me           # OBRIGATÓRIO (web) — openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000  # OBRIGATÓRIO (web)

# === CORS ===
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001  # OPCIONAL

# === Telegram ===
TELEGRAM_BOT_TOKEN=...            # OBRIGATÓRIO (bot) — BotFather no Telegram
TELEGRAM_CHAT_ID=...              # OBRIGATÓRIO (notificações) — ID do chat/canal
ALLOWED_TELEGRAM_IDS=123456789    # OPCIONAL — IDs autorizados no webhook (vírgulas)

# === Google Workspace OAuth ===
GOOGLE_CLIENT_ID=...              # OBRIGATÓRIO (Google integração) — Google Cloud Console
GOOGLE_CLIENT_SECRET=...          # OBRIGATÓRIO (Google integração) — Google Cloud Console
GOOGLE_REFRESH_TOKEN=...          # OBRIGATÓRIO (Google integração) — gerado via OAuth flow
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback  # OPCIONAL

# === Notion ===
NOTION_API_KEY=secret_...         # OPCIONAL — notion.so/my-integrations
NOTION_DATABASE_ID=...            # OPCIONAL — Clients database ID
NOTION_TASKS_DATABASE_ID=...      # OPCIONAL — Tasks database ID

# === ClickUp ===
CLICKUP_API_TOKEN=pk_...          # OPCIONAL — Personal token em Settings → Apps
CLICKUP_TEAM_ID=...               # OPCIONAL — Workspace ID da URL
CLICKUP_DEFAULT_LIST_ID=...       # OPCIONAL — ID da lista padrão para tasks
CLICKUP_ID_LIST=...               # OPCIONAL — alias alternativo para CLICKUP_DEFAULT_LIST_ID
CLICKUP_USER_ID=...               # OPCIONAL — Settings → Profile → User ID
CLICKUP_CLIENT_ID=...             # OPCIONAL — OAuth app (se usar OAuth flow)
CLICKUP_CLIENT_SECRET=...         # OPCIONAL — OAuth app secret
CLICKUP_REDIRECT_URI=http://localhost:3001/api/auth/clickup/callback  # OPCIONAL

# === Meta Ads (Atlas Traffic Squad) ===
META_ACCESS_TOKEN=EAAxxxxxx...    # OPCIONAL — Meta Business → System User token
META_ACCESS_TOKEN_PETY=EAAxxxxx  # OPCIONAL — token específico conta Pety
META_ACCESS_TOKEN_ERICK=EAAxxxxx # OPCIONAL — token específico conta Erick
META_AD_ACCOUNT_ID=act_123456789 # OPCIONAL — ID da conta de anúncios Meta

# === Atlas (Autonomous Ad Optimizer) ===
ATLAS_WRITE_ENABLED=false         # OPCIONAL — habilita ações reais (pausar/criar ads)
ATLAS_SCHEDULER_TOKEN=...         # OPCIONAL — token de autenticação do scheduler
ATLAS_DEFAULT_WORKSPACE=erick     # OPCIONAL — workspace padrão para o Atlas
ATLAS_DEFAULT_ACCOUNT_ID=...      # OPCIONAL — conta Meta padrão do Atlas

# === Scheduler (GitHub Actions → API) ===
SCHEDULER_SECRET=...              # OBRIGATÓRIO (scheduled tasks) — string secreta para autenticar GH Actions

# === Maverick (Content Generation) ===
MAVERICK_ENABLED=true             # OPCIONAL — habilita scheduled tasks do Maverick
MAVERICK_CAROUSEL_ENABLED=true    # OPCIONAL — habilita endpoint /carousel
MAVERICK_CACHE_TTL_HOURS=24       # OPCIONAL — TTL do cache de análises (horas)

# === Figma (Carousel Export) ===
FIGMA_API_TOKEN=figd_...          # OPCIONAL — figma.com/developers → Personal Access Token
FIGMA_FILE_KEY=ABC123xyz          # OPCIONAL — key do arquivo Figma destino (da URL)

# === ElevenLabs TTS ===
ELEVENLABS_API_KEY=sk_...         # OPCIONAL — elevenlabs.io/app → API Keys
ELEVENLABS_VOICE_ID=...           # OPCIONAL — ID da voz preferida
ELEVENLABS_MODEL=eleven_multilingual_v2  # OPCIONAL — modelo TTS
EL_STABILITY=0.75                 # OPCIONAL — estabilidade da voz (0-1)
EL_SIMILARITY=0.85                # OPCIONAL — similaridade da voz (0-1)
EL_STYLE=0.05                     # OPCIONAL — estilo da voz (0-1)

# === Serper (Google Search — Trend Researcher) ===
SERPER_API_KEY=...                # OPCIONAL — serper.dev (busca Google para Reels)
