# ARIA Production Environment Template
# Copy to .env and fill in values

# --- Server ---
NODE_ENV=production
PORT=3001

# --- API Keys ---
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# --- JWT ---
JWT_SECRET=

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notion ---
NOTION_WORKSPACE_URL=

# --- Sentry (Error Tracking) ---
SENTRY_DSN=

# --- Deployment ---
RAILWAY_TOKEN=
PRODUCTION_URL=
